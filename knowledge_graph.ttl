ex:casa_de_pilatos a tour:Entity ;
    rdfs:label "Casa de Pilatos…" ;
    tour:description "Alfalfa y Encarnación, el corazón de Sevilla En pleno centro histórico, es una de las zonas más interesantes y dinámicas de la ciudad. Combina siglos de historia y tradición con un ambiente moderno y creativo donde se respira vida a cualquier hora. Es el lugar perfecto para pasear, descubrir rincone" ;
    tour:label "Casa de Pilatos…" ;
    tour:latitude "37.390269146758"^^xsd:float ;
    tour:longDescription "Alfalfa y Encarnación, el corazón de Sevilla En pleno centro histórico, es una de las zonas más interesantes y dinámicas de la ciudad. Combina siglos de historia y tradición con un ambiente moderno y creativo donde se respira vida a cualquier hora. Es el lugar perfecto para pasear, descubrir rincone" ;
    tour:longitude "-5.98698876277906"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Curiosidades ¿Sabías que en Sevilla existe un “David” de Miguel Ángel? Cuando pensamos en el David de Miguel Ángel, nuestra mente viaja directamente a Florencia, a la perfección del mármol y al esplendor del Renacimiento italiano" ;
    tour:type "TraditionalMarket" ;
    tour:url "https://visitasevilla.es/sabias-que-en-sevilla-hay-una-ruta-que-cuenta-la-pasion-de-cristo-en-azulejos" ;
    tour:wikidataId "Q1046529" .

