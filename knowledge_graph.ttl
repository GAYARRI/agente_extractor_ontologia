        "https://visitasevilla.es/sevilla-es-una-ciudad-para-el-deporte",
        "https://visitasevilla.es/sharm-sevilla" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Oficina que ofrece información turística específica de Sevilla." ;
    tour:sourceUrl "https://visitasevilla.es/durante-tu-estancia" ;
