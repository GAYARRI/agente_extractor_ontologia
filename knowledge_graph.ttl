ex:turismo_responsable a tour:Entity ;
    rdfs:label "Turismo Responsable" ;
    tour:description "Verde y sostenible Pamplona/Iruña huele a hierba mojada y aire de los Pirineos. A la gran cantidad de zonas verdes que se extienden por toda la ciudad, se suma el parque fluvial donde se refugia una gran biodiversidad. L a evolución histórica y urbanística de Pamplona ha favorecido una ciudad camina" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/06/Huerta_pamplons_sostenible-1-scaled-e1749468727273.jpg" ;
    tour:label "Turismo Responsable" ;
    tour:longDescription "Verde y sostenible Pamplona/Iruña huele a hierba mojada y aire de los Pirineos. A la gran cantidad de zonas verdes que se extienden por toda la ciudad, se suma el parque fluvial donde se refugia una gran biodiversidad. L a evolución histórica y urbanística de Pamplona ha favorecido una ciudad camina" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/06/Huerta_pamplons_sostenible-1-scaled-e1749468727273.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Verde y sostenible Pamplona/Iruña huele a hierba mojada y aire de los Pirineos" ;
    tour:type "Location",
        "Thing" ;
    tour:url "https://visitpamplonairuna.com/descubre-pamplona/verde-y-sostenible" .

ex:universidad_publica a tour:Entity ;
    rdfs:label "Universidad Pública" ;
    tour:description "Barrio a barrio El Casco Antiguo de Pamplona y sus ensanches son el epicentro de la ciudad. Allí se encuentran los tres burgos que la conformaron y su planta medieval, así como sus mercados, plazuelas y todos los edificios históricos que recuerdan que fue capital de un gran reino. Al norte Al sur Al" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/01/Universidad-Publica-de-Navarra.png" ;
    tour:label "Universidad Pública" ;
    tour:longDescription "Barrio a barrio El Casco Antiguo de Pamplona y sus ensanches son el epicentro de la ciudad. Allí se encuentran los tres burgos que la conformaron y su planta medieval, así como sus mercados, plazuelas y todos los edificios históricos que recuerdan que fue capital de un gran reino. Al norte Al sur Al" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/01/Universidad-Publica-de-Navarra.png" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Historia de la ciudad Origen Siglos IV-X Siglos IX-XII Siglo XVI Siglos XVIII Siglos XIX Con raíces en el pueblo vascón de Iruña, Pamplona ha evolucionado a lo largo de los siglos hasta convertirse en la ciudad actual" ;
    tour:type "Location",
        "Thing" ;
    tour:url "https://visitpamplonairuna.com/descubre-pamplona/barrio-a-barrio" .

