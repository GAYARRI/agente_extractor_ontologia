@prefix ex: <http://example.org/resource/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tour: <http://example.org/tourism/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:Atlántico a <Ocean> ;
    rdfs:label "Atlántico" ;
    tour:confidence 9e-01 ;
    tour:nearWater "Atlantic Ocean" ;
    tour:type "WaterBody" .

ex:Carnaval_Internacional a <Festival> ;
    rdfs:label "Carnaval Internacional" ;
    tour:confidence 9e-01 ;
    tour:eventType "CulturalEvent" ;
    tour:locatedIn "Gran Canaria" .

ex:Gran_Canaria a <Island> ;
    rdfs:label "Gran Canaria" ;
    tour:category "GeographicalFeature" ;
    tour:confidence 9e-01 ;
    tour:hasWildlife "Cetaceans" ;
    tour:locatedIn "Gran Canaria" ;
    tour:type "Island" .

ex:Los_Bigotes a <Place> ;
    rdfs:label "Los Bigotes" ;
    tour:confidence 3e-01 ;
    tour:type "Location" .

ex:Montaña a <NaturalArea> ;
    rdfs:label "Montaña" ;
    tour:confidence 9e-01 ;
    tour:type "NaturalArea" .

ex:San_Bartolomé a <Municipality> ;
    rdfs:label "San Bartolomé" ;
    tour:confidence 9e-01 ;
    tour:locatedIn "Gran Canaria" ;
    tour:type "AdministrativeArea" .

ex:Valle_de_las_Mil_Palmeras a <Valley> ;
    rdfs:label "Valle de las Mil Palmeras" ;
    tour:confidence 9e-01 ;
    tour:type "NaturalFormation" .

