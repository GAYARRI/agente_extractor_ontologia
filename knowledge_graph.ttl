ex:fronton_jito_alai a tour:Entity ;
    rdfs:label "Frontón Jito Alai" ;
    tour:description "Pelota Vasca en Pamplona, una historia compartida Pamplona esconde un tesoro deportivo que cautiva a locales y visitantes por igual: la pelota vasca. Deporte de reyes, curas y, sobre todo, del pueblo. En el caso de Pamplona hay noticias de su práctica desde la época medieval. La práctica de la pelot" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/03/001PAMPLONA_PELOTAZALE_dburguiDBIZ3794-scaled.jpg" ;
    tour:label "Frontón Jito Alai" ;
    tour:longDescription "Pelota Vasca en Pamplona, una historia compartida Pamplona esconde un tesoro deportivo que cautiva a locales y visitantes por igual: la pelota vasca. Deporte de reyes, curas y, sobre todo, del pueblo. En el caso de Pamplona hay noticias de su práctica desde la época medieval. La práctica de la pelot" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/03/001PAMPLONA_PELOTAZALE_dburguiDBIZ3794-scaled.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Pelota Vasca en Pamplona, una historia compartida Pamplona esconde un tesoro deportivo que cautiva a locales y visitantes por igual: la pelota vasca" ;
    tour:type "Location",
        "Unknown" ;
    tour:url "https://visitpamplonairuna.com/descubre-pamplona/pelota-vasca-en-pamplona" .

