    tour:type "Tower" ;
    tour:url "https://visitasevilla.es/torre-sevilla-y-mirador-torre-atalaya" .

ex:torre_del_oro a tour:Entity ;
    rdfs:label "Torre del Oro" ;
    tour:description "Torre del Oro La Torre del Oro es uno de los símbolos más reconocibles de Sevilla. Fue construida por los almohades a comienzos del siglo XIII como torre defensiva para controlar el acceso al río Guadalquivir . A lo largo de su historia ha sido almacén, capilla, prisión y hoy alberga el Museo Naval" ;
    tour:image "https://visitasevilla.es/wp-content/uploads/2025/06/Sevilla_TDS_TorreDelOro_AlejandroVerdugo_09.08.24_2-1024x682.jpg" ;
    tour:label "Torre del Oro" ;
    tour:longDescription "Torre del Oro La Torre del Oro es uno de los símbolos más reconocibles de Sevilla. Fue construida por los almohades a comienzos del siglo XIII como torre defensiva para controlar el acceso al río Guadalquivir . A lo largo de su historia ha sido almacén, capilla, prisión y hoy alberga el Museo Naval" ;
    tour:mainImage "https://visitasevilla.es/wp-content/uploads/2025/06/Sevilla_TDS_TorreDelOro_AlejandroVerdugo_09.08.24_2-1024x682.jpg" ;
    tour:score "0.8"^^xsd:float ;
    tour:shortDescription "Torre del Oro La Torre del Oro es uno de los símbolos más reconocibles de Sevilla" ;
    tour:type "Tower" ;
    tour:url "https://visitasevilla.es/torre-del-oro-2" ;
    tour:wikidataId "Q943873" .

