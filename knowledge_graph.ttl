ex:parque_de_maria a tour:Entity ;
    rdfs:label "Parque de María" ;
    tour:email "visitasevilla@sevillacityoffice.es" ;
    tour:label "Parque de María" ;
    tour:longDescription "El Parque de María es un espacio verde destacado en la ciudad, famoso por su diseño paisajístico y diversas esculturas, incluyendo la estatua que representa el amor en tres fases. Es un lugar de esparcimiento y atracción turística, ideal para paseos y actividades al aire libre." ;
    tour:relatedUrls "https://visitasevilla.es/sabias-que-esta-estatua-del-parque-de-maria-luisa-representa-el-amor-en-tres-fases" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Parque emblemático en la ciudad, conocido por su belleza y esculturas." ;
    tour:sourceUrl "https://visitasevilla.es/que-hacer-en-sevilla/parques" ;
    tour:type "Place" .

