ex:parque_fluvial a tour:Entity ;
    rdfs:label "Parque Fluvial" ;
    tour:description "Barrio a barrio El Casco Antiguo de Pamplona y sus ensanches son el epicentro de la ciudad. Allí se encuentran los tres burgos que la conformaron y su planta medieval, así como sus mercados, plazuelas y todos los edificios históricos que recuerdan que fue capital de un gran reino. Al norte Al sur Al" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/01/Parque-Fluvial-del-Arg.png" ;
    tour:label "Parque Fluvial" ;
    tour:longDescription "Barrio a barrio El Casco Antiguo de Pamplona y sus ensanches son el epicentro de la ciudad. Allí se encuentran los tres burgos que la conformaron y su planta medieval, así como sus mercados, plazuelas y todos los edificios históricos que recuerdan que fue capital de un gran reino. Al norte Al sur Al" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/01/Parque-Fluvial-del-Arg.png" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Barrio a barrio El Casco Antiguo de Pamplona y sus ensanches son el epicentro de la ciudad" ;
    tour:type "Basilica",
        "Location" ;
    tour:url "https://visitpamplonairuna.com/descubre-pamplona/barrio-a-barrio" .

