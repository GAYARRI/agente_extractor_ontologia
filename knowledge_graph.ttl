@prefix ex: <http://example.org/resource/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tour: <http://example.org/tourism/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ayuntamiento_de_sevilla a tour:Entity ;
    rdfs:label "Ayuntamiento de Sevilla" ;
    tour:description "Consulados / Embajadas Consulta el listado actualizado de Consulados y Embajadas radicadas en Sevilla. Ver listado > Salud Si tienes alguna necesidad relacionada con la salud accede a la siguiente página con toda la información actualizada. Ir a página > Objetos perdidos ¿Has perdido algo? Acude al servicio de objetos perdidos del Ayuntamiento de Sevilla. Ir a página > Policía Si necesitas acudir a la policía llama al 091 o accede a la siguiente página para más información. Ir a página > Culto no católico Encuentra tu lugar de oración. Ver listado > Servicio de consignas Encuentra los espacios para dejar tus pertenencias de manera segura. Ir a página >" ;
    tour:label "Ayuntamiento de Sevilla" ;
    tour:longDescription "El Ayuntamiento de Sevilla es la institución gubernamental que se encarga de la administración de la ciudad. Ofrece diversos servicios a los ciudadanos y turistas, incluyendo el servicio de objetos perdidos, facilitando la recuperación de pertenencias extraviadas en la ciudad." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Institución pública de Sevilla que gestiona servicios locales." ;
    tour:sourceUrl "https://visitasevilla.es/durante-tu-estancia" ;
    tour:type "Organization" .

ex:bicicleta_sevilla a tour:Entity ;
    rdfs:label "Bicicleta Sevilla" ;
    tour:description "Sevilla siempre ha sido una ciudad fácil, llana, soleada… y eso había que aprovecharlo, también sobre dos ruedas. Por eso se habilitaron kilómetros y kilómetros de carril bici a lo largo de toda Sevilla, y se puso en marcha un servicio público de alquiler de bicicletas denominado Sevici. Sevici Más información" ;
    tour:label "Bicicleta Sevilla" ;
    tour:longDescription "Sevilla es una ciudad conocida por su clima soleado y su topografía llana, lo que la convierte en un destino ideal para el ciclismo. Con una amplia red de carriles bici, Sevilla ofrece a los visitantes la oportunidad de explorar sus encantos de una manera activa y saludable, disfrutando de sus paisajes y cultura a través de paseos en bicicleta." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Ciudad de Sevilla, conocida por su infraestructura ciclista." ;
    tour:sourceUrl "https://visitasevilla.es/durante-tu-estancia" ;
    tour:type "Place" .

ex:dormir_descubre a tour:Entity ;
    rdfs:label "Dormir Descubre" ;
    tour:description "Descubre alojamientos únicos en Sevilla, espacios en los que cada estancia es un hechizo de comodidad y elegancia. Sumérgete en la esencia de una ciudad llena de encanto y deja que cada rincón te sorprenda con su magia inigualable. Elige dónde hospedarte" ;
    tour:image "https://visitasevilla.es/wp-content/uploads/2024/08/prueba-portada-landing-v1.jpg" ;
    tour:label "Dormir Descubre" ;
    tour:longDescription "Dormir Descubre ofrece una selección de alojamientos únicos en Sevilla, donde cada estancia promete comodidad y elegancia, permitiendo a los turistas sumergirse en la esencia encantadora de la ciudad." ;
    tour:mainImage "https://visitasevilla.es/wp-content/uploads/2024/08/prueba-portada-landing-v1.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Alojamientos únicos en Sevilla." ;
    tour:sourceUrl "https://visitasevilla.es/sharm-sevilla" ;
    tour:type "Accommodation" .

ex:embajadas_consulta a tour:Entity ;
    rdfs:label "Embajadas Consulta" ;
    tour:description "Consulados / Embajadas Consulta el listado actualizado de Consulados y Embajadas radicadas en Sevilla. Ver listado > Salud Si tienes alguna necesidad relacionada con la salud accede a la siguiente página con toda la información actualizada. Ir a página > Objetos perdidos ¿Has perdido algo? Acude al servicio de objetos perdidos del Ayuntamiento de Sevilla. Ir a página > Policía Si necesitas acudir a la policía llama al 091 o accede a la siguiente página para más información. Ir a página > Culto no católico Encuentra tu lugar de oración. Ver listado > Servicio de consignas Encuentra los espacios para dejar tus pertenencias de manera segura. Ir a página >" ;
    tour:label "Embajadas Consulta" ;
    tour:longDescription "Embajadas Consulta se refiere a la información sobre las embajadas y consulados ubicados en Sevilla, que son instituciones que representan a sus países y ofrecen servicios a sus ciudadanos, así como información útil para turistas y residentes." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Listado de embajadas en Sevilla." ;
    tour:sourceUrl "https://visitasevilla.es/durante-tu-estancia" ;
    tour:type "Organization" .

ex:empresa_taxi_adaptado a tour:Entity ;
    rdfs:label "Empresa Taxi Adaptado" ;
    tour:address "(piloto verde)" ;
    tour:description "Los taxis en Sevilla son cómodos, seguros y disponibles 24/7, ideales para trayectos rápidos, con maletas o fuera del horario de transporte público. Son blancos con una franja amarilla, se pueden tomar en paradas, por teléfono, apps o en la calle (piloto verde). El precio varía por taxímetro, con tarifas más altas de noche, festivos o desde aeropuerto/estación. Teléfonos útiles: Tele Taxi Sevilla: +34 954 622 222 Radio Taxi Sevilla: +34 954 580 000 Para evitar retrasos, le recomendamos reservar un taxi adaptado con antelación. Servicio de taxi para personas con discapacidad física +34 954 476 060 Empresa: Taxi Adaptado +34 623 913 223 Sevimovial +34 629 103 019 Taxi Sevilla Radio Taxi Sevill" ;
    tour:label "Empresa Taxi Adaptado" ;
    tour:longDescription "Empresa Taxi Adaptado es un servicio en Sevilla que se especializa en ofrecer taxis adaptados para personas con discapacidad. Se puede contactar para reservar un taxi adaptado, asegurando un transporte accesible y cómodo." ;
    tour:phone "+34 954 622 222" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Servicio de taxi adaptado para personas con discapacidad." ;
    tour:sourceUrl "https://visitasevilla.es/durante-tu-estancia" ;
    tour:type "LocalBusiness" .

ex:feria_de_sevilla a tour:Entity ;
    rdfs:label "Feria de Sevilla" ;
    tour:label "Feria de Sevilla" ;
    tour:longDescription "La Feria de Sevilla es un evento anual que se celebra en la ciudad de Sevilla, España. Es conocida por su ambiente festivo, con casetas, música, baile y una amplia variedad de actividades culturales. La feria atrae a miles de visitantes cada año, quienes disfrutan de la gastronomía local, espectáculos y la tradicional iluminación de la portada, que marca el inicio de las festividades." ;
    tour:relatedUrls "https://visitasevilla.es/sabias-que-la-portada-de-la-feria-de-sevilla-tiene-mas-bombillas-que-la-torre-eiffel" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Feria anual con atracciones y actividades culturales en Sevilla." ;
    tour:sourceUrl "https://visitasevilla.es/que-hacer-en-sevilla/fiestas-en-sevilla" ;
    tour:type "Event" .

ex:leon_prado a tour:Entity ;
    rdfs:label "León Prado" ;
    tour:address "Ponce de León Prado San Sebastián (junto a la parada de Metro_Centro) Tussam Cómo llegar al Aeropuerto" ;
    tour:description "La red de bus de Sevilla es muy extensa, y quizás sea el medio preferido por los sevillanos. En la mayoría de las paradas puedes encontrar puntos NFC de servicio gracias a los cuales verás en tu móvil el tiempo de espera y todo tipo de información de la ciudad. También suelen existir pantallas con el dato de los próximos autobuses y sus tiempos de llegada. Toda la flota está monitorizada por GPS. Teléfonos de atención al cliente: 010 955 010 010 Puntos de información y venta: Taquilla en Plaza Ponce de León Prado San Sebastián (junto a la parada de Metro_Centro) Tussam Cómo llegar al Aeropuerto" ;
    tour:label "León Prado" ;
    tour:longDescription "León Prado se refiere a una zona que está vinculada a la Plaza Ponce de León, siendo parte del paisaje urbano que los turistas pueden explorar, aunque su relevancia es menor en comparación con las plazas mencionadas." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Zona asociada a la Plaza Ponce de León." ;
    tour:sourceUrl "https://visitasevilla.es/durante-tu-estancia" ;
    tour:type "Place" .

ex:monumentos_de_sevilla a tour:Entity ;
    rdfs:label "monumentos de Sevilla" ;
    tour:description "Una manera de conocer el amplio y rico patrimonio histórico-artístico de Sevilla es realizando una visita guiada acompañado por un profesional que puede explicarte la historia, leyendas y anécdotas de los monumentos de Sevilla. Visitas guiadas en Sevilla" ;
    tour:label "monumentos de Sevilla" ;
    tour:longDescription "Los monumentos de Sevilla son una serie de atracciones turísticas que reflejan la rica historia y cultura de la ciudad. Incluyen catedrales, palacios y otros edificios significativos que son visitados por turistas que buscan conocer más sobre la herencia cultural de la región." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Conjunto de atracciones históricas en Sevilla." ;
    tour:sourceUrl "https://visitasevilla.es/durante-tu-estancia" ;
    tour:type "TouristAttraction" .

ex:museo a tour:Entity ;
    rdfs:label "Museo" ;
    tour:description "Mil historias. 10 barrios. Un destino inolvidable. Explora la ciudad con nuestro mapa interactivo: Diez barrios, diez formas de vivir Sevilla Alfalfa y Encarnación ¡Descubre el barrio! Triana y Los Remedios ¡Descubre el barrio! Nervión ¡Descubre el barrio! La Macarena…" ;
    tour:image "https://visitasevilla.es/wp-content/uploads/2025/06/barrio-museo-y-plaza-nueva-sevilla-1024x576.jpg" ;
    tour:label "Museo" ;
    tour:longDescription "El Museo es un espacio cultural en Sevilla que alberga diversas exposiciones y colecciones de arte, historia y cultura, siendo un lugar de interés para aquellos que desean profundizar en la herencia cultural de la ciudad." ;
    tour:mainImage "https://visitasevilla.es/wp-content/uploads/2025/06/barrio-museo-y-plaza-nueva-sevilla-1024x576.jpg" ;
    tour:relatedUrls "https://visitasevilla.es/barrio-del-museo-y-plaza-nueva" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Espacio cultural que alberga exposiciones y colecciones." ;
    tour:sourceUrl "https://visitasevilla.es/mapa-interactivo-sevilla" ;
    tour:type "TouristAttraction" .

ex:oficina_de_turismo_de_sevilla a tour:Entity ;
    rdfs:label "Oficina de Turismo de Sevilla" ;
    tour:label "Oficina de Turismo de Sevilla" ;
    tour:longDescription "La Oficina de Turismo de Sevilla es un organismo dedicado a proporcionar información y asistencia a los turistas que visitan la ciudad, facilitando recursos y recomendaciones para disfrutar al máximo de la experiencia sevillana." ;
    tour:relatedUrls "https://visitasevilla.es/ahora-en-sevilla",
        "https://visitasevilla.es/comer-salir-sevilla",
