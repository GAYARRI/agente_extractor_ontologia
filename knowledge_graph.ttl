ex:blanca_jimenez a tour:Entity ;
    rdfs:label "Blanca Jiménez" ;
    tour:description "Volver al inicio Valladolid refuerza su liderazgo en turismo accesible Compartir turismo 10 de abril de 2026 La concejala de Turismo, Eventos y Marca Ciudad y vicepresidenta de la Sociedad Mixta para la Promoción del Turismo de Valladolid, Blanca Jiménez, y el presidente de la IMPULSA IGUALDAD Casti" ;
    tour:label "Blanca Jiménez" ;
    tour:longDescription "Volver al inicio Valladolid refuerza su liderazgo en turismo accesible Compartir turismo 10 de abril de 2026 La concejala de Turismo, Eventos y Marca Ciudad y vicepresidenta de la Sociedad Mixta para la Promoción del Turismo de Valladolid, Blanca Jiménez, y el presidente de la IMPULSA IGUALDAD Casti" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Volver al inicio Valladolid muestra en FITUR 2025 su consolidación como ‘Ciudad de Cine’ tras un año récord en rodajes Compartir 23 de enero de 2025 La concejala de Turismo, Eventos y Marca Ciudad, Blanca Jiménez, y el coordinador de Valladolid Film Commission y presidente de Spain Film Commission, Juan Manuel Guimeráns, han presentado en el marco de la Feria Internacional de Turismo, que se celebra estos días en Madrid, la consolidación de Valladolid como ‘Ciudad de Cine’ en el último año gracias a la atracción de nuevos rodajes a la ciudad y el impulso de un creciente tejido productivo local" ;
    tour:type "Event",
        "Monument" ;
    tour:url "https://info.valladolid.es/noticias/la-semana-santa-de-valladolid-se-presenta-en-madrid-como-un-evento-unico-que-une-tradicion%5C" ;
    tour:wikidataId "Q16196079" .

