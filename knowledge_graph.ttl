ex:sidrerias_en_pamplona a tour:Entity ;
    rdfs:label "Sidrerías En Pamplona" ;
    tour:description "Gastronomía Navarra tiene sabor a tradición y en Pamplona se puede comprobar. Una increíble variedad de productos locales, procedentes de un diverso paisaje, combinados con recetarios históricos, toques de innovación y vanguardia, y el gusto por convertir cualquier acto gastronómico en acontecimient" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/10/pintxoscortada.jpg" ;
    tour:label "Sidrerías En Pamplona" ;
    tour:longDescription "Gastronomía Navarra tiene sabor a tradición y en Pamplona se puede comprobar. Una increíble variedad de productos locales, procedentes de un diverso paisaje, combinados con recetarios históricos, toques de innovación y vanguardia, y el gusto por convertir cualquier acto gastronómico en acontecimient" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/10/pintxoscortada.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Gastronomía Navarra tiene sabor a tradición y en Pamplona se puede comprobar" ;
    tour:type "Location",
        "Unknown" ;
    tour:url "https://visitpamplonairuna.com/descubre-pamplona/gastronomia" .

