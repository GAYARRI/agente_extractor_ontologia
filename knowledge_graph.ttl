ex:cerveceria_el_grifo a tour:Entity ;
    rdfs:label "Cervecería El Grifo" ;
    tour:description "Curiosidades Día Internacional de la Cerveza: ¿Cuál es la más fría de Sevilla? El Día Internacional de la Cerveza (1 de agosto) llega con un récord que sólo podía nacer en la ciudad de la “caña bien tirada”: la cuenta @SevillaResiste recorrió una docena de tabernas con un termómetro digital y descub" ;
    tour:label "Cervecería El Grifo" ;
    tour:longDescription "Curiosidades Día Internacional de la Cerveza: ¿Cuál es la más fría de Sevilla? El Día Internacional de la Cerveza (1 de agosto) llega con un récord que sólo podía nacer en la ciudad de la “caña bien tirada”: la cuenta @SevillaResiste recorrió una docena de tabernas con un termómetro digital y descub" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Curiosidades Día Internacional de la Cerveza: ¿Cuál es la más fría de Sevilla? El Día Internacional de la Cerveza (1 de agosto) llega con un récord que sólo podía nacer en la ciudad de la “caña bien tirada”: la cuenta @SevillaResiste recorrió una docena de tabernas con un termómetro digital y descubrió dos bares que bajan la Cruzcampo hasta los 2,3 grados bajo cero, auténtico hielo líquido para combatir los 40 °C del verano hispalense" ;
    tour:type "Bar" ;
    tour:url "https://visitasevilla.es/dia-internacional-de-la-cerveza-cual-es-la-mas-fria-de-sevilla" .

