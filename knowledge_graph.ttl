ex:macarena_la_basilica a tour:Entity ;
    rdfs:label "Macarena La Basílica" ;
    tour:description "Basílica y murallas de la Macarena La Basílica de la Macarena y el tramo de muralla almohade que la acompaña son dos hitos fundamentales del patrimonio de Sevilla. Se encuentran en el barrio de la Macarena, una zona cargada de historia y tradición, fácilmente accesible tanto a pie como en transporte" ;
    tour:image "https://visitasevilla.es/wp-content/uploads/2025/06/Basilica-de-la-Macarena-1024x715.jpg" ;
    tour:label "Macarena La Basílica" ;
    tour:longDescription "Basílica y murallas de la Macarena La Basílica de la Macarena y el tramo de muralla almohade que la acompaña son dos hitos fundamentales del patrimonio de Sevilla. Se encuentran en el barrio de la Macarena, una zona cargada de historia y tradición, fácilmente accesible tanto a pie como en transporte" ;
    tour:mainImage "https://visitasevilla.es/wp-content/uploads/2025/06/Basilica-de-la-Macarena-1024x715.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Monumentos 7 planes para disfrutar de Sevilla en San Valentín" ;
    tour:type "Basilica" ;
    tour:url "https://visitasevilla.es/basilica-y-murallas-de-la-macarena" .

ex:macarena_nuestra a tour:Entity ;
    rdfs:label "Macarena Nuestra" ;
    tour:description "Descubre esta ruta gastro por la zona norte de Sevilla Sevilla es una ciudad llena de encanto, de tradición y de vanguardia. Y también, de sabores deliciosos . La ciudad tiene lugares increíbles para disfrutar de la buena cocina, desde las tapas más tradicionales a innovadores platos. No te pierdas" ;
    tour:label "Macarena Nuestra" ;
    tour:latitude "37.4106887"^^xsd:float ;
    tour:longDescription "Descubre esta ruta gastro por la zona norte de Sevilla Sevilla es una ciudad llena de encanto, de tradición y de vanguardia. Y también, de sabores deliciosos . La ciudad tiene lugares increíbles para disfrutar de la buena cocina, desde las tapas más tradicionales a innovadores platos. No te pierdas" ;
    tour:longitude "-5.9778949"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Descubre esta ruta gastro por la zona norte de Sevilla Sevilla es una ciudad llena de encanto, de tradición y de vanguardia" ;
    tour:type "TraditionalMarket" ;
    tour:url "https://visitasevilla.es/ruta-gastro-norte-sevilla" .

