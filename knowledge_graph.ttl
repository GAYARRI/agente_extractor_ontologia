ex:ruta_de_cine a tour:Entity ;
    rdfs:label "Ruta de Cine" ;
    tour:description "Volver al inicio Pañoleta especial 25 aniversario Compartir Otras de las acciones especiales durante este año, será el reparto de una pañoleta oficial entre los vecinos de la ciudad con el que el Ayuntamiento ha hecho un esfuerzo extraordinario para que la ciudadanía tenga un bonito recuerdo de esta" ;
    tour:image "https://admin.info.valladolid.es/sites/default/files/styles/scale_webp_640x360/public/2025-12/Ruta%20del%20Cine%20Rodaje%20San%20Pablo%20Valladolid.jpg.webp?itok=dP4Xu6Yu" ;
    tour:label "Ruta de Cine" ;
    tour:longDescription "Volver al inicio Pañoleta especial 25 aniversario Compartir Otras de las acciones especiales durante este año, será el reparto de una pañoleta oficial entre los vecinos de la ciudad con el que el Ayuntamiento ha hecho un esfuerzo extraordinario para que la ciudadanía tenga un bonito recuerdo de esta" ;
    tour:mainImage "https://admin.info.valladolid.es/sites/default/files/styles/scale_webp_640x360/public/2025-12/Ruta%20del%20Cine%20Rodaje%20San%20Pablo%20Valladolid.jpg.webp?itok=dP4Xu6Yu" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Volver al inicio Ruta de Cine Compartir ¡Valladolid, una ciudad de Cine! La oficina de Turismo de Valladolid pone en marcha una nueva visita para conocer las localizaciones de grandes películas, series y momentos de cine vividos en nuestra ciudad La iniciativa nace con la intención de que todos los vecinos y visitantes tengan la oportunidad de profundizar en la estrecha relación que mantiene Valladolid con el séptimo arte gracias, entre otros muchos aspectos, a su condición de Ciudad Creativa del Cine por la Unesco" ;
    tour:type "Route" ;
    tour:url "https://info.valladolid.es/panoleta-especial-25-aniversario%5C" .

