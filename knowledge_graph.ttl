ex:pamplona_parques a tour:Entity ;
    rdfs:label "Pamplona Parques" ;
    tour:description "Pamplona bizi-bizirik Iruña muy viva Con un profundo legado histórico y mirada contemporánea, Pamplona no se explica con una lista de monumentos, hay que vivirla. Aquí, lo mejor ocurre mientras se pasea sin prisa por los parques, las murallas y sus animadas calles; o se degusta un pintxo con el soni" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/10/Mercados-imprescindibles-en-Pamplona-para-vivir-como-una-persona-local.jpg" ;
    tour:label "Pamplona Parques" ;
    tour:longDescription "Pamplona bizi-bizirik Iruña muy viva Con un profundo legado histórico y mirada contemporánea, Pamplona no se explica con una lista de monumentos, hay que vivirla. Aquí, lo mejor ocurre mientras se pasea sin prisa por los parques, las murallas y sus animadas calles; o se degusta un pintxo con el soni" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/10/Mercados-imprescindibles-en-Pamplona-para-vivir-como-una-persona-local.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Pamplona bizi-bizirik Iruña muy viva Con un profundo legado histórico y mirada contemporánea, Pamplona no se explica con una lista de monumentos, hay que vivirla" ;
    tour:type "Location",
        "Monument" ;
    tour:url "https://visitpamplonairuna.com/" .

