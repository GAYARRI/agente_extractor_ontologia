ex:ayuntamiento_de_pamplona_plaza_consistorial a tour:Entity ;
    rdfs:label "Ayuntamiento de Pamplona Plaza Consistorial" ;
    tour:description "Descubre Pamplona Abierta, diversa y con profundas raíces, combina la herencia de siglos con una mirada contemporánea. Aquí, cada calle, plaza o edificio cuenta una historia; cada fiesta, una emoción compartida. Descubre Pamplona desde una mirada tranquila, caminando, de forma pausada, porque Pamplo" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/03/001PAMPLONA_PELOTAZALE_dburguiDBIZ3794-scaled.jpg" ;
    tour:label "Ayuntamiento de Pamplona Plaza Consistorial" ;
    tour:longDescription "Descubre Pamplona Abierta, diversa y con profundas raíces, combina la herencia de siglos con una mirada contemporánea. Aquí, cada calle, plaza o edificio cuenta una historia; cada fiesta, una emoción compartida. Descubre Pamplona desde una mirada tranquila, caminando, de forma pausada, porque Pamplo" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/03/001PAMPLONA_PELOTAZALE_dburguiDBIZ3794-scaled.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Historia de la ciudad Origen Siglos IV-X Siglos IX-XII Siglo XVI Siglos XVIII Siglos XIX Con raíces en el pueblo vascón de Iruña, Pamplona ha evolucionado a lo largo de los siglos hasta convertirse en la ciudad actual" ;
    tour:type "Location",
        "Square",
        "TownHall" ;
    tour:url "https://visitpamplonairuna.com/descubre-pamplona/pelota-vasca-en-pamplona" .

ex:camino_baztanes a tour:Entity ;
    rdfs:label "Camino Baztanés" ;
    tour:description "Camino de Santiago El Camino de Santiago es una de las rutas de peregrinación más importantes a nivel mundial, y Pamplona/Iruña es parada ineludible de esta gran experiencia, el Camino. Situada en pleno camino a Compostela, Pamplona es la primera ciudad en el peregrinaje desde Roncesvalles. El Camin" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/01/hojas-camino-santiago.jpg" ;
    tour:label "Camino Baztanés" ;
    tour:longDescription "Camino de Santiago El Camino de Santiago es una de las rutas de peregrinación más importantes a nivel mundial, y Pamplona/Iruña es parada ineludible de esta gran experiencia, el Camino. Situada en pleno camino a Compostela, Pamplona es la primera ciudad en el peregrinaje desde Roncesvalles. El Camin" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/01/hojas-camino-santiago.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Camino de Santiago El Camino de Santiago es una de las rutas de peregrinación más importantes a nivel mundial, y Pamplona/Iruña es parada ineludible de esta gran experiencia, el Camino" ;
    tour:type "Location",
        "Unknown" ;
    tour:url "https://visitpamplonairuna.com/descubre-pamplona/camino-de-santiago" .

