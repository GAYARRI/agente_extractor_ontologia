    tour:longitude "-1.6296261"^^xsd:float ;
    tour:mainImage "https://visitasevilla.es/wp-content/uploads/2022/11/ES_Sevilla_Ceramica_Santa_Ana-170725152213-copia.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "DE COMPRAS El arte alfarero Sevilla se caracteriza por su industria artesana protagonizada principalmente por la cerámica y la alfarería" ;
    tour:type "Monument" ;
    tour:url "https://visitasevilla.es/ceramica" .

