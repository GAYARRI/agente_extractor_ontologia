ex:la_memoria_del_palacio_real a tour:Entity ;
    rdfs:label "La memoria del Palacio Real" ;
    tour:description "Volver al inicio La memoria del Palacio Real Compartir Comprar entradas Comprar entradas La memoria del Palacio Real La visita teatralizada 'La memoria del Palacio Real' es un original paseo por la historia de un enclave que fue hogar de reyes y emperadores como Carlos I, Isabel de Portugal o Felipe" ;
    tour:image "https://admin.info.valladolid.es/sites/default/files/styles/scale_webp_640x360/public/2024-12/Navidad%20en%20Palacio%20Real%202024.png.webp?itok=wzmbh4Kx" ;
    tour:label "La memoria del Palacio Real" ;
    tour:longDescription "Volver al inicio La memoria del Palacio Real Compartir Comprar entradas Comprar entradas La memoria del Palacio Real La visita teatralizada 'La memoria del Palacio Real' es un original paseo por la historia de un enclave que fue hogar de reyes y emperadores como Carlos I, Isabel de Portugal o Felipe" ;
    tour:mainImage "https://admin.info.valladolid.es/sites/default/files/styles/scale_webp_640x360/public/2024-12/Navidad%20en%20Palacio%20Real%202024.png.webp?itok=wzmbh4Kx" ;
    tour:score "0.8"^^xsd:float ;
    tour:shortDescription "Volver al inicio La memoria del Palacio Real Compartir Comprar entradas Comprar entradas La memoria del Palacio Real La visita teatralizada 'La memoria del Palacio Real' es un original paseo por la historia de un enclave que fue hogar de reyes y emperadores como Carlos I, Isabel de Portugal o Felipe II, además de oros personajes determinantes para nuestra historia como Lord Wellington, Napoleón o Santa Teresa" ;
    tour:type "Palace" ;
    tour:url "https://info.valladolid.es/la-memoria-del-palacio-real%5C" .

