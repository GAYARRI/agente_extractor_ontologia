ex:ruta_por a tour:Entity ;
    rdfs:label "Ruta por" ;
    tour:description "La Sevilla de comienzos del siglo XX vivió un resurgir arquitectónico que transformó su paisaje urbano: el regionalismo . Este movimiento, que combinó el espíritu andaluz con las nuevas corrientes europeas, reinterpretó estilos como el mudéjar , el gótico o el renacimiento desde una mirada moderna." ;
    tour:image "https://visitasevilla.es/wp-content/uploads/2025/10/ES_Sevilla_Plaza_Espana.jpg" ;
    tour:label "Ruta por" ;
    tour:longDescription "La Sevilla de comienzos del siglo XX vivió un resurgir arquitectónico que transformó su paisaje urbano: el regionalismo . Este movimiento, que combinó el espíritu andaluz con las nuevas corrientes europeas, reinterpretó estilos como el mudéjar , el gótico o el renacimiento desde una mirada moderna." ;
    tour:mainImage "https://visitasevilla.es/wp-content/uploads/2025/10/ES_Sevilla_Plaza_Espana.jpg" ;
    tour:score "0.8"^^xsd:float ;
    tour:shortDescription "La Sevilla de comienzos del siglo XX vivió un resurgir arquitectónico que transformó su paisaje urbano: el regionalismo" ;
    tour:type "Route" ;
    tour:url "https://visitasevilla.es/ruta-por-la-sevilla-regionalista-redescubre-la-ciudad-a-traves-de-su-arquitectura" ;
    tour:wikidataId "Q126206699" .

