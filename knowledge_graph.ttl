@prefix ex: <http://example.org/resource/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix tour: <http://example.org/tourism/> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

ex:ayuntamiento_de_pamplona_plaza_consistorial a tour:Entity ;
    rdfs:label "Ayuntamiento de Pamplona Plaza Consistorial" ;
    tour:description "Pamplona bizi-bizirik Iruña muy viva Con un profundo legado histórico y mirada contemporánea, Pamplona no se explica con una lista de monumentos, hay que vivirla. Aquí, lo mejor ocurre mientras se pasea sin prisa por los parques, las murallas y sus animadas calles; o se degusta un pintxo con el soni" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/03/001PAMPLONA_PELOTAZALE_dburguiDBIZ3794-scaled.jpg" ;
    tour:label "Ayuntamiento de Pamplona Plaza Consistorial" ;
    tour:latitude "42.8061705"^^xsd:float ;
    tour:longDescription "Pamplona bizi-bizirik Iruña muy viva Con un profundo legado histórico y mirada contemporánea, Pamplona no se explica con una lista de monumentos, hay que vivirla. Aquí, lo mejor ocurre mientras se pasea sin prisa por los parques, las murallas y sus animadas calles; o se degusta un pintxo con el soni" ;
    tour:longitude "-1.5903973"^^xsd:float ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/03/001PAMPLONA_PELOTAZALE_dburguiDBIZ3794-scaled.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Cultura muy viva Un paseo por sus calles te permitirá respirar la cultura y esencia de la ciudad: rincones que te transportan a un pasacalles de San Fermín ; conchas que anuncian que, tras el paso de los Pirineos, entras a la primera del Camino de Santiago ; patrimonio histórico artístico con más de 5 kilómetros de murallas renacentistas excepcionales; frontones secretos donde descubrir la pelota vasca o barras de bar que atesoran una gastronomía sublime basada en el producto local" ;
    tour:type "Location",
        "Square",
        "TownHall" ;
    tour:url "https://visitpamplonairuna.com/descubre-pamplona/pelota-vasca-en-pamplona" .

ex:cafe_iruna a tour:Entity ;
    rdfs:label "Café Iruña" ;
    tour:description "San Fermín San Fermín es la fiesta más emblemática de Pamplona. Celebrada del 6 al 14 de julio, esta festividad declarada de Interés Turístico Internacional, atrae cada año a miles de visitantes de todo el mundo. Aunque es mundialmente conocida por sus encierros, San Fermín es mucho más: alegría, am" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/10/Chupinazo-2.jpg" ;
    tour:label "Café Iruña" ;
    tour:longDescription "San Fermín San Fermín es la fiesta más emblemática de Pamplona. Celebrada del 6 al 14 de julio, esta festividad declarada de Interés Turístico Internacional, atrae cada año a miles de visitantes de todo el mundo. Aunque es mundialmente conocida por sus encierros, San Fermín es mucho más: alegría, am" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/10/Chupinazo-2.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "San Fermín San Fermín es la fiesta más emblemática de Pamplona" ;
    tour:type "Location",
        "Unknown" ;
    tour:url "https://visitpamplonairuna.com/descubre-pamplona/san-fermin" .

ex:castillo_lugares a tour:Entity ;
    rdfs:label "Castillo Lugares" ;
    tour:description "Todos los lugares Lugares de interés Iglesias y catedral Monumentos Museos y centros de interpretación Mercados Qué ver Un paseo por Pamplona-Iruña es un auténtico viaje en el tiempo, desde la esencia del poblado vascón hasta los más actuales ejemplos de arquitectura contemporánea. Si quieres saber" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/01/Plaza_castillo-portada-1.jpg" ;
    tour:label "Castillo Lugares" ;
    tour:longDescription "Todos los lugares Lugares de interés Iglesias y catedral Monumentos Museos y centros de interpretación Mercados Qué ver Un paseo por Pamplona-Iruña es un auténtico viaje en el tiempo, desde la esencia del poblado vascón hasta los más actuales ejemplos de arquitectura contemporánea. Si quieres saber" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/01/Plaza_castillo-portada-1.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Todos los lugares Lugares de interés Iglesias y catedral Monumentos Museos y centros de interpretación Mercados Qué ver Un paseo por Pamplona-Iruña es un auténtico viaje en el tiempo, desde la esencia del poblado vascón hasta los más actuales ejemplos de arquitectura contemporánea" ;
    tour:type "Castle",
        "Location" ;
    tour:url "https://visitpamplonairuna.com/tipo-lugar/que-ver" .

ex:centro_de_acogida a tour:Entity ;
    rdfs:label "Centro de Acogida" ;
    tour:description "Camino de Santiago El Camino de Santiago es una de las rutas de peregrinación más importantes a nivel mundial, y Pamplona/Iruña es parada ineludible de esta gran experiencia, el Camino. Situada en pleno camino a Compostela, Pamplona es la primera ciudad en el peregrinaje desde Roncesvalles. El Camin" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/01/ultria.jpg" ;
    tour:label "Centro de Acogida" ;
    tour:longDescription "Camino de Santiago El Camino de Santiago es una de las rutas de peregrinación más importantes a nivel mundial, y Pamplona/Iruña es parada ineludible de esta gran experiencia, el Camino. Situada en pleno camino a Compostela, Pamplona es la primera ciudad en el peregrinaje desde Roncesvalles. El Camin" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/01/ultria.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Camino de Santiago El Camino de Santiago es una de las rutas de peregrinación más importantes a nivel mundial, y Pamplona/Iruña es parada ineludible de esta gran experiencia, el Camino" ;
    tour:type "Location",
        "Unknown" ;
    tour:url "https://visitpamplonairuna.com/descubre-pamplona/camino-de-santiago" .

