ex:san_nicolas a tour:Entity ;
    rdfs:label "San Nicolás" ;
    tour:description "Gastronomía Navarra tiene sabor a tradición y en Pamplona se puede comprobar. Una increíble variedad de productos locales, procedentes de un diverso paisaje, combinados con recetarios históricos, toques de innovación y vanguardia, y el gusto por convertir cualqui" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/08/pinchos_pintxos-1024x683.jpg" ;
    tour:label "San Nicolás" ;
    tour:longDescription "Gastronomía Navarra tiene sabor a tradición y en Pamplona se puede comprobar. Una increíble variedad de productos locales, procedentes de un diverso paisaje, combinados con recetarios históricos, toques de innovación y vanguardia, y el gusto por convertir cualquier acto gastronómico en acontecimient" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/08/pinchos_pintxos-1024x683.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Privilegio de la Unión 08/09/2026 - 08/09/2026 Con el Privilegio de la Unión , promulgado y firmado por el rey Carlos III el Noble el 8 de septiembre de 1423, se puso fin a los constantes conflictos y a las rivalidades entre los tres burgos en torno a los cuales había crecido la ciudad entre los siglos XI y XII: la ciudad de la Navarrería , el burgo de San Cernin y la población de San Nicolás" ;
    tour:type "Event",
        "Monument" ;
    tour:url "https://visitpamplonairuna.com/planifica-tu-viaje/donde-comer/de-pintxos-y-cazuelicas" .

