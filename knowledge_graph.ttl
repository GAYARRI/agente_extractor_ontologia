    tour:mainImage "https://visitasevilla.es/wp-content/uploads/2025/06/Sevilla-Teatro-de-la-Maestranza-Nitro-30-de-julio-de-2021-IMG_0831-1024x683.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "El Arenal, historia y vida junto al Guadalquivir El Arenal es uno de los barrios más tradicionales, animados y con más carácter de Sevilla" ;
    tour:type "Theater" ;
    tour:url "https://visitasevilla.es/barrio-de-el-arenal" .

