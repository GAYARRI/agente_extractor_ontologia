ex:sevilla_florece a tour:Entity ;
    rdfs:label "Sevilla Florece" ;
    tour:email "visitasevilla@sevillacityoffice.es" ;
    tour:label "Sevilla Florece" ;
    tour:longDescription "Sevilla Florece es un evento que celebra la floración de los naranjos en la ciudad de Sevilla, destacando la belleza de sus calles y la cultura local. Este evento atrae a turistas interesados en la naturaleza y la tradición sevillana, ofreciendo actividades y recorridos que resaltan la importancia de los naranjos en la identidad de la ciudad." ;
    tour:relatedUrls "https://visitasevilla.es/sevilla-florece-por-que-hay-tantos-naranjos-en-la-ciudad" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Evento relacionado con la floración de naranjos en Sevilla." ;
    tour:sourceUrl "https://visitasevilla.es/que-hacer-en-sevilla/parques" ;
    tour:type "Event" .

ex:viernes_santo a tour:Entity ;
    rdfs:label "Viernes Santo" ;
    tour:address "de San Francisco, 19 De lunes a domingo: 09:30-14:30h y 15:30-18:30h Horario especial Semana Santa (de Domingo de Ramos a Sábado Santo): 9:30-15:00h" ;
