    tour:longitude "-5.9307039"^^xsd:float ;
    tour:mainImage "https://visitasevilla.es/wp-content/uploads/2025/06/DSC03556-1024x576.jpg" ;
    tour:score "0.8"^^xsd:float ;
    tour:shortDescription "Parque Infanta Elena El Parque Infanta Elena es uno de los grandes espacios verdes del este de Sevilla, ubicado en el barrio de Sevilla Este" ;
    tour:type "Garden" ;
    tour:url "https://visitasevilla.es/parque-infanta-elena" .

