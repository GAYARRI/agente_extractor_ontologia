ex:temporada_taurina a tour:Entity ;
    rdfs:label "Temporada Taurina" ;
    tour:label "Temporada Taurina" ;
    tour:longDescription "La Temporada Taurina en Sevilla es un evento anual que rinde homenaje a la tradición de la tauromaquia, atrayendo a aficionados y turistas. Durante esta temporada, se llevan a cabo corridas de toros en la famosa Plaza de Toros de la Maestranza, convirtiéndose en un punto de interés cultural y turístico." ;
    tour:relatedUrls "https://visitasevilla.es/culmina-la-temporada-taurina-en-sevilla-un-tributo-al-arte-de-torear" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Evento que celebra la tradición de la tauromaquia en Sevilla." ;
    tour:sourceUrl "https://visitasevilla.es/que-hacer-en-sevilla/fiestas-en-sevilla" ;
    tour:type "Event" .

ex:vela_de_san_miguel a tour:Entity ;
    rdfs:label "Velá de San Miguel" ;
    tour:label "Velá de San Miguel" ;
    tour:longDescription "La Velá de San Miguel es una feria que se celebra en Sevilla durante el otoño, en honor a San Miguel. Este evento incluye actividades festivas, música y gastronomía, y es una oportunidad para que los sevillanos y turistas disfruten de la cultura local en un ambiente festivo." ;
    tour:relatedUrls "https://visitasevilla.es/la-vela-de-san-miguel-la-feria-de-otono-de-sevilla" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Feria de otoño en Sevilla con actividades culturales." ;
    tour:sourceUrl "https://visitasevilla.es/que-hacer-en-sevilla/fiestas-en-sevilla" ;
    tour:type "Event" .

ex:vela_de_triana a tour:Entity ;
    rdfs:label "Velá de Triana" ;
    tour:label "Velá de Triana" ;
    tour:longDescription "La Velá de Triana es la fiesta más antigua de Sevilla, celebrada en honor a Santa Ana. Este evento cultural y religioso incluye actividades festivas, música y tradiciones locales, atrayendo tanto a residentes como a turistas que desean experimentar la cultura sevillana." ;
    tour:relatedUrls "https://visitasevilla.es/sabias-que-la-vela-de-triana-en-honor-a-santa-ana-es-la-fiesta-mas-antigua-de-sevilla" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Fiesta tradicional de Sevilla en honor a Santa Ana." ;
    tour:sourceUrl "https://visitasevilla.es/que-hacer-en-sevilla/fiestas-en-sevilla" ;
    tour:type "Event" .

ex:zona_monumental a tour:Entity ;
    rdfs:label "zona monumental" ;
    tour:address "turístico" ;
    tour:description "Sevilla dispone de una línea de metro. Se trata de un metro ligero muy reciente, muy moderno, que cruza la ciudad de Este a Oeste (llegando a conectar con el área metropolitana). El Metrocentro es la versión en superficie del metro para llegar al corazón mismo de Sevilla, a su zona monumental. Su recorrido ya es en sí un paseo turístico. Teléfonos de Atención al Cliente: 900 927 172 954 540 785 Horarios habituales De lunes a jueves: de 06:30 a 23:00 horas Viernes y vísperas de festivos: De 06:30 a 02:00 horas Sábados: de 07:30 a 02:00 horas Domingos y festivos: de 07:30 a 23:00 horas Metro Sevilla" ;
    tour:label "zona monumental" ;
    tour:longDescription "La zona monumental de Sevilla es un área que alberga importantes monumentos y sitios históricos, como la Catedral, la Giralda y el Alcázar. Es un punto focal para los turistas que desean explorar la herencia cultural y arquitectónica de la ciudad." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Área histórica y cultural de Sevilla." ;
    tour:sourceUrl "https://visitasevilla.es/durante-tu-estancia" ;
    tour:type "Place" .

