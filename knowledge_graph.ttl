ex:luis_bronce a tour:Entity ;
    rdfs:label "Luis Bronce" ;
    tour:description "Monumento a Ernest Hemingway El conjunto escultórico se compone de un gran bloque de granito de Guadarrama, cuya parte inferior se configura a modo de pedestal, en tanto que la superior esboza de manera sintética el torso y brazos del escritor -Premio Nobel de Literatura- y periodista estadounidense" ;
    tour:image "https://esculturas.pamplona.es/wp-content/uploads/sites/15/2022/02/hemingway-luis-sangino-01-385x575.webp" ;
    tour:label "Luis Bronce" ;
    tour:longDescription "Monumento a Ernest Hemingway El conjunto escultórico se compone de un gran bloque de granito de Guadarrama, cuya parte inferior se configura a modo de pedestal, en tanto que la superior esboza de manera sintética el torso y brazos del escritor -Premio Nobel de Literatura- y periodista estadounidense" ;
    tour:mainImage "https://esculturas.pamplona.es/wp-content/uploads/sites/15/2022/02/hemingway-luis-sangino-01-385x575.webp" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Monumento a Ernest Hemingway El conjunto escultórico se compone de un gran bloque de granito de Guadarrama, cuya parte inferior se configura a modo de pedestal, en tanto que la superior esboza de manera sintética el torso y brazos del escritor -Premio Nobel de Literatura- y periodista estadounidense Ernest Hemingway, ataviado con su característico jersey de cuello vuelto y en actitud de presenciar una corrida de toros apoyado en la barrera de la plaza" ;
    tour:type "Monument" ;
    tour:url "https://visitpamplonairuna.com/lugar/monumento-a-ernest-hemingway" .

