ex:san_fermin_entre_tambores a tour:Entity ;
    rdfs:label "San Fermín entre tambores" ;
    tour:description """Ir al contenido
Reserva tu actividad
Sanfermines para todos: tradición, cultura y emoción compartida
A quien diga que San Fermín es solo encierro y fiesta habría que invitarle a pasear —sin prisa y con ojos nuevos— por Pamplona en julio. Porque estas fiestas esconden algo más profundo: una celebraci""" ;
    tour:image "https://visitpamplonairuna.com/wp-content/uploads/2025/07/sanfermines-para-todos-los-publicos-tradicoon-cultura-y-experiencias-imprescindibles.jpg" ;
    tour:label "San Fermín entre tambores" ;
    tour:longDescription "Ir al contenido Reserva tu actividad Sanfermines para todos: tradición, cultura y emoción compartida A quien diga que San Fermín es solo encierro y fiesta habría que invitarle a pasear —sin prisa y con ojos nuevos— por Pamplona en julio. Porque estas fiestas esconden algo más profundo: una celebraci" ;
    tour:mainImage "https://visitpamplonairuna.com/wp-content/uploads/2025/07/sanfermines-para-todos-los-publicos-tradicoon-cultura-y-experiencias-imprescindibles.jpg" ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Ir al contenido Reserva tu actividad Sanfermines para todos: tradición, cultura y emoción compartida A quien diga que San Fermín es solo encierro y fiesta habría que invitarle a pasear —sin prisa y con ojos nuevos— por Pamplona en julio" ;
    tour:type "Event",
        "Location" ;
    tour:url "https://visitpamplonairuna.com/sanfermines-para-todos" .

ex:transporte_urbano_comarcal a tour:Entity ;
    rdfs:label "Transporte Urbano Comarcal" ;
    tour:description """Ir al contenido
