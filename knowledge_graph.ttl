ex:terrazas_y_diversion_al_sol a tour:Entity ;
    rdfs:label "Terrazas y diversión al sol" ;
    tour:description "VIVE SEVILLA / Gastronomía Una ciudad que irradia luz Sevilla te invita a disfrutarla desde primera hora: su luz espectacular, su gastronomía, la vida en la calle, la diversión compartida… No te querrás perder todo esto, ¿verdad? ¡El sol te hace brillar! Si buscas estar al aire libre, tienes infinid" ;
    tour:image "https://visitasevilla.es/wp-content/uploads/2022/11/terrazas-diversion-bloque-2.jpg" ;
    tour:label "Terrazas y diversión al sol" ;
    tour:longDescription "VIVE SEVILLA / Gastronomía Una ciudad que irradia luz Sevilla te invita a disfrutarla desde primera hora: su luz espectacular, su gastronomía, la vida en la calle, la diversión compartida… No te querrás perder todo esto, ¿verdad? ¡El sol te hace brillar! Si buscas estar al aire libre, tienes infinid" ;
    tour:mainImage "https://visitasevilla.es/wp-content/uploads/2022/11/terrazas-diversion-bloque-2.jpg" ;
    tour:score "0.8"^^xsd:float ;
    tour:shortDescription "VIVE SEVILLA / Gastronomía Una ciudad que irradia luz Sevilla te invita a disfrutarla desde primera hora: su luz espectacular, su gastronomía, la vida en la calle, la diversión compartida… No te querrás perder todo esto, ¿verdad? ¡El sol te hace brillar! Si buscas estar al aire libre, tienes infinidad de terrazas donde relajarte todo el día y quedarte hasta el atardecer" ;
    tour:type "Monument" ;
    tour:url "https://visitasevilla.es/terrazas-y-diversion-al-sol" .

