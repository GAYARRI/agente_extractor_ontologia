res:caminos a onto:naturalarea ;
    rdfs:label "Caminos" ;
    onto:description "Camino de Ayagaures Entre presas, pinares y suaves lomas, este recorrido combina naturaleza, silencio y vistas espectaculares.",
        "Camino de Fataga Una de las rutas más emblemáticas: serpentea entre palmerales y riscos hasta el “Valle de las Mil Palmeras”.",
        "Rutas de senderos Caminos que unen el mar y las cumbres, entre paisajes cambiantes y huellas de historia." ;
    onto:image "https://turismo.maspalomas.com/uploads/fataga_11f534673f.jpg",
