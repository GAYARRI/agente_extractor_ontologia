@prefix onto: <http://tourismkg.com/ontology/> .
@prefix prov1: <http://tourismkg.com/provenance/> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix res: <http://tourismkg.com/resource/> .

res:actividades a onto:activity ;
    rdfs:label "Actividades" ;
    onto:description "Actividades en el Mar Disfruta del Atlántico en todo su esplendor: navega, bucea o surfea entre aguas cristalinas y paisajes únicos. Maspalomas te invita a vivir el mar como nunca antes." ;
    onto:image "https://turismo.maspalomas.com/uploads/bg_video_2d80688385.jpg" ;
    prov1:extractor "hybrid_extractor" ;
    prov1:source "https://turismo.maspalomas.com/actividades-en-el-mar" .

res:aquí a onto:hotel,
        onto:naturalarea ;
    rdfs:label "Aquí" ;
    onto:description "Hospitalidad y bienestar Hoteles con encanto, centros de bienestar, gastronomía local y un trato cercano. Aquí el visitante no solo descansa, sino que se siente parte de un lugar donde la vida se disfruta sin prisas.",
        "Un clima perfecto todo el año Más de 300 días de sol y temperaturas suaves entre 21 y 25 °C. En Maspalomas, el invierno se siente como verano y el verano nunca es extremo. Ideal para disfrutar del mar, la montaña o simplemente desconectar bajo el cielo azul. Playas para todos los gustos Desde las dunas infinitas de Maspalomas hasta las calas tranquilas de Meloneras o lSan Agustín. Naturaleza y paisajes únicos Barrancos, palmerales, pinares y acantilados volcánicos crean un mosaico de ecosistemas en pocos kilómetros. Aventura y ocio Camellos, senderismo, karting, buceo, golf o parques temáticos. Maspalomas ofrece diversión sin límites, combinando adrenalina, naturaleza y experiencias en familia o con amigos. Cultura, historia y tradiciones Un municipio que ha sabido crecer sin perder sus raíces. Romerías, artesanía, folclore y una gastronomía con alma canaria te harán sentir la autenticidad del lugar. Hospitalidad y bienestar Hoteles con encanto, centros de bienestar, gastronomía local y un trato cercano. Aquí el visitante no solo descansa, sino que se siente parte de un lugar donde la vida se disfruta sin prisas." ;
    onto:image "https://turismo.maspalomas.com/uploads/6razones1_bb090ccc2f.jpg",
        "https://turismo.maspalomas.com/uploads/gastronomia_8608477d07.jpg" ;
    onto:locatedin res:maspalomas,
        res:maspalomas_famosa,
        res:maspalomas_un,
        res:maspalomas_vive,
        res:meloneras,
        res:meloneras_elegante ;
    prov1:extractor "hybrid_extractor" ;
    prov1:source "https://turismo.maspalomas.com/seis-razones-para-visitarnos" .

res:atlántico a onto:naturalarea ;
    rdfs:label "Atlántico" ;
    onto:description "Actividades en el Mar Disfruta del Atlántico en todo su esplendor: navega, bucea o surfea entre aguas cristalinas y paisajes únicos. Maspalomas te invita a vivir el mar como nunca antes.",
        "Pesca de altura Vive la emoción del Atlántico en su máxima expresión. Zarpa desde Pasito Blanco y desafía a gigantes del mar como el atún, el pez espada o el marlín azul.",
        "Playas Arena dorada, sol eterno y el Atlántico en calma." ;
    onto:image "https://turismo.maspalomas.com/uploads/bg_video_2d80688385.jpg",
        "https://turismo.maspalomas.com/uploads/pesca_ca6dbe25c1.jpg",
        "https://turismo.maspalomas.com/uploads/playas_2b5350faff.jpg" ;
    onto:locatedin res:pasito_blanco ;
    prov1:extractor "hybrid_extractor" ;
    prov1:source "https://turismo.maspalomas.com/actividades-en-el-mar",
        "https://turismo.maspalomas.com/playas" .

res:aventura a onto:naturalarea ;
    rdfs:label "Aventura" ;
    onto:description "Aventura y ocio Camellos, senderismo, karting, buceo, golf o parques temáticos. Maspalomas ofrece diversión sin límites, combinando adrenalina, naturaleza y experiencias en familia o con amigos.",
        "Un clima perfecto todo el año Más de 300 días de sol y temperaturas suaves entre 21 y 25 °C. En Maspalomas, el invierno se siente como verano y el verano nunca es extremo. Ideal para disfrutar del mar, la montaña o simplemente desconectar bajo el cielo azul. Playas para todos los gustos Desde las dunas infinitas de Maspalomas hasta las calas tranquilas de Meloneras o lSan Agustín. Naturaleza y paisajes únicos Barrancos, palmerales, pinares y acantilados volcánicos crean un mosaico de ecosistemas en pocos kilómetros. Aventura y ocio Camellos, senderismo, karting, buceo, golf o parques temáticos. Maspalomas ofrece diversión sin límites, combinando adrenalina, naturaleza y experiencias en familia o con amigos. Cultura, historia y tradiciones Un municipio que ha sabido crecer sin perder sus raíces. Romerías, artesanía, folclore y una gastronomía con alma canaria te harán sentir la autenticidad del lugar. Hospitalidad y bienestar Hoteles con encanto, centros de bienestar, gastronomía local y un trato cercano. Aquí el visitante no solo descansa, sino que se siente parte de un lugar donde la vida se disfruta sin prisas." ;
    onto:image "https://turismo.maspalomas.com/uploads/6razones1_bb090ccc2f.jpg",
        "https://turismo.maspalomas.com/uploads/cetaceos_ba28c5584f.webp" ;
    onto:locatedin res:maspalomas,
        res:maspalomas_famosa,
        res:maspalomas_un,
        res:maspalomas_vive,
        res:meloneras,
        res:meloneras_elegante ;
    prov1:extractor "hybrid_extractor" ;
    prov1:source "https://turismo.maspalomas.com/seis-razones-para-visitarnos" .

