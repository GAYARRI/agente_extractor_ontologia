ex:espana_este a tour:Entity ;
    rdfs:label "España Este" ;
    tour:description "Comenzamos nuestra visita a Valladolid en la Plaza Mayor , la primera plaza mayor regular de España. Este espacio, reconstruido a instancias de Felipe II en el siglo XVI después de un incendio que arrasó la zona, ha sido modelo de otras plazas regulares, con soportales y cerradas. El color rojo que" ;
    tour:label "España Este" ;
    tour:longDescription "España Este se refiere a una región geográfica que abarca varias comunidades autónomas en el este del país. Esta área es conocida por su diversidad cultural, paisajes variados y una rica historia. Aunque no es un destino turístico específico, incluye ciudades y lugares de interés que atraen a visitantes, contribuyendo a la oferta turística de España." ;
    tour:score "0.75"^^xsd:float ;
