ex:castillos a tour:Entity ;
    rdfs:label "castillos" ;
    tour:description "Situado en la localidad de Curiel de Duero, Valladolid, corazón de la región vitivinícola de la Ribera de Duero. En el interior del recinto se ha edificado un lujoso complejo hotelero de 26 habitaciones y suites,salones, restaurante, comedores para banquetes, salas de conferencias, salas de música, | localidad del departamento de Rocha, Uruguay" ;
    tour:label "castillos" ;
