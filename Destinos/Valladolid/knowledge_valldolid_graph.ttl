ex:casamuseo_de_cristobal_colon a tour:Entity ;
    rdfs:label "CasaMuseo de Cristóbal Colón" ;
    tour:description "Valladolid, ciudad donde murió Cristóbal Colón (el 20 de mayo de 1506 en el convento de San Francisco), dedica al descubridor una casa-museo que se centra en sus diversas facetas: hombre, marinero, diplomático, negociador, comerciante, etc. Recorre el Mediterráneo y el Atlántico, recuerda su periplo" ;
    tour:label "CasaMuseo de Cristóbal Colón" ;
    tour:latitude "41.6534285"^^xsd:float ;
    tour:longDescription "La Casa Museo de Cristóbal Colón en Valladolid es un espacio cultural que explora la vida del descubridor a través de exposiciones interactivas. Alberga una colección precolombina y ofrece visitas guiadas, siendo un recurso didáctico para escolares y grupos. Su arquitectura imita el palacio de su hijo en Santo Domingo." ;
    tour:longitude "-4.7180415"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Museo dedicado a la vida y viajes de Cristóbal Colón." ;
    tour:type "https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource" ;
    tour:url "https://info.valladolid.es/casa-museo-colon" .

