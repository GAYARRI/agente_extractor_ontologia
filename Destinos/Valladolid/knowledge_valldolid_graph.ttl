ex:sauvignon_blanc a tour:Entity ;
    rdfs:label "Sauvignon Blanc" ;
    tour:description "El origen de los vinos blancos de Emina procede de parcelas de viñedo propio y la Sauvignon Blanc. | 2026 single by Rosalía" ;
    tour:label "Sauvignon Blanc" ;
    tour:longDescription "La Sauvignon Blanc es una variedad de uva blanca originaria de Francia, conocida por su frescura y acidez. Es utilizada en la producción de vinos blancos, destacando por sus notas herbáceas y frutales. En el contexto de Emina, esta variedad se cultiva en parcelas de viñedo propio, contribuyendo a la producción de vinos de alta calidad." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Variedad de uva utilizada para vinos blancos." ;
    tour:type "Thing" ;
    tour:url "https://info.valladolid.es/disfruta/enoturismo" .

