ex:escuela_castellana a tour:Entity ;
    rdfs:label "Escuela Castellana" ;
    tour:description "Se trata de imágenes que no solo capturan la escena, sino también el profundo sentimiento del cofrade riosecano en los diversos momentos de los desfiles procesionales. Asimismo, estas fotografías ponen de relieve el extraordinario patrimonio artístico de sus pasos, obras de destacados escultores de" ;
    tour:label "Escuela Castellana" ;
    tour:longDescription "La Escuela Castellana es un movimiento artístico que se desarrolló en España durante los siglos XVI y XVII, conocido por su influencia en la escultura y el arte religioso. Sus obras son reconocidas por su calidad y su contribución al patrimonio cultural, especialmente en el contexto de las procesiones y festividades religiosas." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Escuela de escultura del siglo XVI y XVII en España." ;
