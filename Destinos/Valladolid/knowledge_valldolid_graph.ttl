ex:archivo_general_de_simancas a tour:Entity ;
    rdfs:label "Archivo General de Simancas" ;
    tour:description "Volver al inicio Catedral Compartir Dirección Calle Arribas, 1. Copiar dirección Abrir en Google Maps Dirección Calle Arribas, 1. Copiar dirección Abrir en Google Maps Teléfono 983 304 362 Sitio Web Ver más Teléfono 983 304 362 Sitio Web Ver más Su mezcla de estilos compone un ejemplar único La Cate | catedral situada en Tarn y Garona, en Francia" ;
    tour:label "Archivo General de Simancas" ;
    tour:latitude "41.6571068"^^xsd:float ;
    tour:longDescription "La Catedral de Nuestra Señora de la Asunción es un edificio emblemático de Valladolid, conocido por su mezcla de estilos y su historia inacabada. Las obras comenzaron en 1527 y, a pesar de los esfuerzos, el templo no se completó. Su torre octogonal actual fue construida a principios del siglo XX. En su interior se destacan las dimensiones y la sobriedad del estilo herreriano." ;
    tour:longitude "-4.7236458"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Archivo histórico que alberga documentos relevantes de la historia de España." ;
