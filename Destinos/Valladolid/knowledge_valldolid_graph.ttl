    tour:longitude "-4.1509557"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Bodega dedicada a la producción de vinos de alta calidad." ;
    tour:type "Thing" ;
    tour:url "https://info.valladolid.es/emilio-moro" .

ex:bodegas_epifanio_rivera a tour:Entity ;
    rdfs:label "Bodegas Epifanio Rivera" ;
    tour:description "La fundación de Bodegas Epifanio Rivera por la familia Rivera-Aparicio entronca con la mas arraigada tradición vitícola de Pesquera de Duero. Desde siempre hemos estado vinculados a la vid. Lo demuestran las viejas viñas de mas de 80 años, la antigua bodega subterránea datada en el Siglo XVI y el la" ;
