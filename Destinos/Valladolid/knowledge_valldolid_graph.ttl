ex:violante_de_aragon a tour:Entity ;
    rdfs:label "Violante de Aragón" ;
    tour:description "Las ruinas adosadas son las de la antigua colegiata, edificio románico de la época del Conde Ansúrez. Como principal templo de la ciudad en aquel momento, fue escenario de importantes celebraciones e hitos históricos, como el enlace entre Alfonso X 'El sabio' y Violante de Aragón. | reina consorte de Castilla (1252-1284)" ;
    tour:label "Violante de Aragón" ;
    tour:longDescription "Violante de Aragón fue la esposa de Alfonso X 'El sabio' y su enlace matrimonial, celebrado en la antigua colegiata, fue un evento significativo en la historia de Castilla. Su figura representa la conexión entre la realeza y la historia cultural de la región." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Reina consorte de Castilla, esposa de Alfonso X." ;
    tour:type "https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource" ;
    tour:url "https://info.valladolid.es/agenda/los-10-imprescindibles" .

