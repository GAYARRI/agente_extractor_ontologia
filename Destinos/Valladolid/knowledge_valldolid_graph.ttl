    tour:latitude "41.6445754"^^xsd:float ;
    tour:longDescription "Bodegas Epifanio Rivera, fundada por la familia Rivera-Aparicio, es un negocio local que se dedica a la producción de vino en Pesquera de Duero. La bodega cuenta con viñas de más de 80 años y una antigua bodega subterránea del Siglo XVI, ofreciendo visitas con degustación de vino." ;
    tour:longitude "-4.157095"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Bodega tradicional en Pesquera de Duero." ;
    tour:type "Thing" ;
    tour:url "https://info.valladolid.es/epifanio-rivera" .

