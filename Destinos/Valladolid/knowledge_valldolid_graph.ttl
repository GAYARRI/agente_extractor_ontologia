ex:nuevo_mundo a tour:Entity ;
    rdfs:label "Nuevo Mundo" ;
    tour:description "Curiosos, sin duda, son los salvajes que aparecen a ambos lados, y que han dado lugar a diferentes interpretaciones. ¿Representan al hombre puro en la naturaleza? ¿Aluden a la costumbre de disfrazar a los escuderos de salvajes en las fiestas? ¿O son, simplemente, guardianes de la puerta? En los cuer | localidad del municipio de Villa Serrano en la provincia de Belisario Boeto, Bolivia" ;
    tour:label "Nuevo Mundo" ;
    tour:latitude "41.6571579"^^xsd:float ;
    tour:longDescription "El Nuevo Mundo se refiere a las tierras descubiertas por los europeos en el continente americano, que incluyen diversas culturas y civilizaciones indígenas. Este término es fundamental en la historia de la colonización y el intercambio cultural entre Europa y América." ;
    tour:longitude "-4.7237065"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Región histórica que abarca América." ;
    tour:type "Place" ;
    tour:url "https://info.valladolid.es/disfruta/patrimonio/monumentos/colegio-de-san-gregorio" .

