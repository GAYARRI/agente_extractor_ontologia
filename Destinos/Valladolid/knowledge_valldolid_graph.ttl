ex:don_diablo a tour:Entity ;
    rdfs:label "Don Diablo" ;
    tour:description "Durante las Fiestas de San Lorenzo 2025, el balcón de la Casa Consistorial volverá a estar habilitado para facilitar el acceso a los conciertos a personas con movilidad reducida, promoviendo así la inclusión y la participación cultural de toda la comunidad. El Ayuntamiento de Valladolid, un año más, | DJ y productor musical neerlandés" ;
    tour:label "Don Diablo" ;
    tour:longDescription "Don Diablo es un reconocido DJ y productor musical que se presentará en un evento musical. Su actuación está programada para comenzar a la medianoche, después de otros artistas como Carlos Jean y Joyse. Este evento es parte de una serie de conciertos que atraen a numerosos asistentes, ofreciendo una experiencia vibrante y entretenida." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "DJ y productor de música electrónica de renombre internacional." ;
