ex:coleccion_precolombina a tour:Entity ;
    rdfs:label "colección precolombina" ;
    tour:description "Valladolid, ciudad donde murió Cristóbal Colón (el 20 de mayo de 1506 en el convento de San Francisco), dedica al descubridor una casa-museo que se centra en sus diversas facetas: hombre, marinero, diplomático, negociador, comerciante, etc. Recorre el Mediterráneo y el Atlántico, recuerda su periplo" ;
    tour:label "colección precolombina" ;
    tour:latitude "41.6534285"^^xsd:float ;
    tour:longDescription "La colección precolombina en el casamuseo de Cristóbal Colón incluye artefactos y objetos que representan la rica cultura de las civilizaciones americanas antes de la llegada de los europeos, ofreciendo una visión profunda de su historia." ;
    tour:longitude "-4.7180415"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Exhibición de artefactos de la América Prehispánica." ;
    tour:type "HistoricalOrCulturalResource" ;
    tour:url "https://info.valladolid.es/casa-museo-colon" .

