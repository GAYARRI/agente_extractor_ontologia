    tour:longitude "-4.71939"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Edificio histórico para eventos y congresos en el centro de la ciudad." ;
    tour:type "Organization" ;
    tour:url "https://info.valladolid.es/profesionales/mice/congresos-eventos/salas-de-reuniones/palacio-de-congresos-conde-ansurez" .

