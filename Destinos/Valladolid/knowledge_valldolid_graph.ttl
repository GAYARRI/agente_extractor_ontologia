    tour:url "https://info.valladolid.es/disfruta/patrimonio/patrimonio-religioso/monasterios-conventos/convento-de-santa-teresa" .

ex:convento_de_san_francisco a tour:Entity ;
    rdfs:label "Convento de San Francisco" ;
    tour:description "El espacio que hoy ocupa la Plaza Mayor de Valladolid surgió como plaza del mercado en la Baja Edad Media, aunque antes se encontraba allí el Postigo del Trigo. Era zona de asiento de mercaderes y oficios, y el lugar para asistir a todo tipo de festejos. En uno de los lados, frente al actual Ayuntam | convento desaparecido de Valladolid (España)" ;
    tour:label "Convento de San Francisco" ;
    tour:latitude "41.652"^^xsd:float ;
    tour:longDescription "El Convento de San Francisco fue uno de los más relevantes complejos monásticos en Valladolid, donde se destacó la figura de Cristóbal Colón. Aunque hoy en día ya no existe, su legado perdura en la historia de la ciudad, siendo un símbolo de la importancia religiosa y cultural de la época." ;
    tour:longitude "-4.72835"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Antiguo convento en Valladolid, importante en la historia local." ;
    tour:type "https://ontologia.segittur.es/turismo/def/core#Convent" ;
    tour:url "https://info.valladolid.es/disfruta/patrimonio/zonas-verdes/plazas/plaza-mayor" .

