ex:ribera_de_duero a tour:Entity ;
    rdfs:label "Ribera de Duero" ;
    tour:description "Tapeo, lechazo y alta gastronomía en el corazón de Valladolid A la hora de comer, sigue descubriendo los sabores de Valladolid. Las tapas son una seña de identidad de la ciudad y el segundo día es ideal para explorar nuevas zonas de tapeo. Además del entorno de la Plaza Mayor y la plaza Martí y Mons" ;
    tour:label "Ribera de Duero" ;
    tour:latitude "41.6238343"^^xsd:float ;
    tour:longDescription "La Ribera de Duero es una prestigiosa denominación de origen en España, conocida por sus vinos de alta calidad. La región se caracteriza por su paisaje y tradición vitivinícola, siendo un destino atractivo para los amantes del vino." ;
    tour:longitude "-4.3269702"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Denominación de origen de vino en Valladolid." ;
    tour:type "Place" ;
    tour:url "https://info.valladolid.es/disfruta/valladolid-1-2-3-dias/valladolid-en-2-dias" .

