ex:1a_estudio a tour:Entity ;
    rdfs:label "1A Estudio" ;
    tour:description "1A. Estudio de vulnerabilidad del sector turístico frente al cambio climático: Contempla la realización de un estudio para analizar el impacto y la vulnerabilidad al cambio climático del sector turístico, así como el establecimiento de una hoja de ruta para identificar y concretar las medidas de ada" ;
    tour:label "1A Estudio" ;
    tour:longDescription "El '1A Estudio' se centra en analizar el impacto del cambio climático en el sector turístico, evaluando su vulnerabilidad y proponiendo una hoja de ruta para implementar medidas de adaptación. Este estudio es relevante para organizaciones y entidades que buscan entender y mitigar los efectos del cambio climático en el turismo." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Estudio sobre vulnerabilidad del turismo al cambio climático." ;
    tour:type "Organization" ;
    tour:url "https://info.valladolid.es/pstd-valladolid-ciudad-creativa" .

ex:2026_semana_santa a tour:Entity ;
    rdfs:label "2026 SEMANA SANTA" ;
    tour:description "Valladolid · 2026 SEMANA SANTA ✦ La pasión en Valladolid 27 Marzo – 5 Abril Saber más Cartel Oficial · 2026" ;
    tour:label "2026 SEMANA SANTA" ;
    tour:longDescription "La Semana Santa de Valladolid es una de las más importantes de España, reconocida por su solemnidad y belleza. En 2026, se celebrará del 27 de marzo al 5 de abril, atrayendo a miles de visitantes que participan en las procesiones y eventos culturales que se llevan a cabo durante esta festividad." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Celebración religiosa que tiene lugar en Valladolid." ;
    tour:type "Event" ;
    tour:url "https://info.valladolid.es" .

