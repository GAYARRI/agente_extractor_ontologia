ex:don_juan a tour:Entity ;
    rdfs:label "Don Juan" ;
    tour:description "Exposiciones, rutas culturales y panorámicas para completar tu visita a Valladolid Tras la comida, continúa este segundo día en Valladolid con más propuestas culturales y al aire libre. Muy cerca del casco histórico encontrarás tres salas municipales de exposiciones de acceso gratuito: Las Francesas | personaje arquetípico" ;
    tour:label "Don Juan" ;
    tour:longDescription "Don Juan es el protagonista de la famosa obra 'Don Juan Tenorio' de José Zorrilla, un personaje que representa la seducción y el desafío a las normas sociales. Su historia es un pilar de la literatura española y está estrechamente vinculada a Valladolid." ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Personaje de la obra 'Don Juan Tenorio'." ;
    tour:type "HistoricalOrCulturalResource" ;
    tour:url "https://info.valladolid.es/disfruta/valladolid-1-2-3-dias/valladolid-en-2-dias" .

