ex:monarquia_hispanica a tour:Entity ;
    rdfs:label "Monarquía Hispánica" ;
    tour:description "Conoce este edificio histórico que conserva la documentación producida por los órganos de gobierno de la Monarquía Hispánica desde la época de los Reyes Católicos hasta la entrada del Régimen Liberal, una iniciativa que arrancó bajo el mandato de Carlos V y que materializó Felipe II. El edificio, un | conjunto de reinos, estados y señoríos independientes entre sí que se hallaban gobernados por igual por el rey de España" ;
    tour:label "Monarquía Hispánica" ;
    tour:latitude "41.659487"^^xsd:float ;
    tour:longDescription "La Monarquía Hispánica fue un periodo clave en la historia de España, abarcando desde los Reyes Católicos hasta el Régimen Liberal, caracterizado por la expansión territorial y cultural." ;
    tour:longitude "-4.7280827"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Período histórico relevante en España." ;
    tour:type "HistoricalOrCulturalResource" ;
    tour:url "https://info.valladolid.es/disfruta/patrimonio/archivos/archivo-general-de-simancas" .

