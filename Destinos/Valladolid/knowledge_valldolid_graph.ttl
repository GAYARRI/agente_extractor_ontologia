ex:catedral_dos a tour:Entity ;
    rdfs:label "Catedral Dos" ;
    tour:description "La construcción de la Catedral comenzó en 1527, bajo la dirección de Rodrigo Gil de Hontañón; sin embargo, cuando el arquitecto murió, cincuenta años después, apenas se había avanzado en la obra. Asumió, pocos años después, la dirección del proyecto Juan de Herrera -responsable, entre otros, de El E" ;
    tour:label "Catedral Dos" ;
