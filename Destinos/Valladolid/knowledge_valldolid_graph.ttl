ex:museo_oriental_de_valladolid a tour:Entity ;
    rdfs:label "Museo Oriental de Valladolid" ;
    tour:description "El Museo Oriental de Valladolid acoge la mejor colección de arte del extremo oriente de España. Atesora piezas de China -lacas, porcelanas, bronces, sedas, numismática, mobiliario, caligrafía, pintura-, de Filipinas -arte etnológico de Luzón y Mindanao; arte colonial- y de Japón –obras de los períod | museo de la ciudad de Valladolid, (España)" ;
    tour:label "Museo Oriental de Valladolid" ;
    tour:latitude "41.6438204"^^xsd:float ;
    tour:longDescription "El Museo Oriental de Valladolid alberga una destacada colección de arte del extremo oriente, incluyendo piezas de China, Filipinas y Japón, que permiten un recorrido por la historia del arte oriental desde el siglo II a.C. hasta el siglo XIX." ;
    tour:longitude "-4.7298547"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Museo con colección de arte oriental en Valladolid." ;
    tour:type "https://ontologia.segittur.es/turismo/def/core#HistoricalOrCulturalResource" ;
    tour:url "https://info.valladolid.es/disfruta/patrimonio/museos-salas-exposiciones/museo-oriental" .

ex:museo_patio_herreriano a tour:Entity ;
    rdfs:label "Museo Patio Herreriano" ;
    tour:description "Cada día, una aventura Descubre nuestros itinerarios para explorar la ciudad Valladolid en un día Valladolid en dos días Valladolid en tres días Los 10 imprescindibles Los sitios icónicos que no puedes dejar de visitar Academia de Caballería Museo Patio Herreriano Plaza Mayor Catedral Museo Nacional | museo de la ciudad de Valladolid, (España)" ;
    tour:label "Museo Patio Herreriano" ;
    tour:latitude "41.654670707623694"^^xsd:float ;
    tour:longDescription "El Museo Patio Herreriano de Arte Contemporáneo Español ofrece un recorrido por el arte nacional desde 1918, destacando obras de artistas como Joan Miró y Salvador Dalí. Su colección incluye más de 400 piezas del Fondo Ángel Ferrant y el museo es accesible para personas con movilidad reducida. La entrada es gratuita y alberga exposiciones temporales." ;
    tour:longitude "-4.730230394251218"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Museo de arte contemporáneo en un antiguo claustro renacentista." ;
    tour:type "TouristAttraction" ;
    tour:url "https://info.valladolid.es/profesionales/mice/congresos-eventos/sedes-singulares/centro-de-congresos-del-museo-patio" .

