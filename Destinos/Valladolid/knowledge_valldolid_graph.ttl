ex:visita_dominio a tour:Entity ;
    rdfs:label "Visita Dominio" ;
    tour:description "La finca donde se encuentra la bodega, LA GRANJA SARDÓN, está vinculada con el Conde de Ansúrez, en el S. XII, por lo que podría considerarse la finca más antigua de España. En 1999, los socios de Granja Sardón fundan Quinta Sardonia, y en 2010 fue adquirido por Terras Gauda, grupo que además cuenta" ;
    tour:label "Visita Dominio" ;
    tour:latitude "41.6157252"^^xsd:float ;
    tour:longDescription "La 'Visita Dominio' permite a los visitantes explorar los viñedos de Granja Sardón, seguido de una degustación de vinos. Esta experiencia está limitada a 7 personas y ofrece una vista privilegiada del valle del Duero, combinando naturaleza y enología." ;
    tour:longitude "-4.4509808"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Visita guiada a los viñedos y bodega de Quinta Sardonia." ;
    tour:type "https://ontologia.segittur.es/turismo/def/core#Itinerary" ;
    tour:url "https://info.valladolid.es/quinta-sardonia" .

