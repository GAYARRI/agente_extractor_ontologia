    tour:latitude "41.1938931"^^xsd:float ;
    tour:longDescription "El yacimiento arqueológico mencionado es un lugar de gran relevancia histórica, donde se han encontrado los restos de una villa romana de los siglos IV y V, lo que lo convierte en un recurso cultural y turístico importante para el estudio del Imperio Romano." ;
    tour:longitude "-4.6687817"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
