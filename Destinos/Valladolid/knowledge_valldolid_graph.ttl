ex:museo_de_valladolid a tour:Entity ;
    rdfs:label "Museo de Valladolid" ;
    tour:description "En 1576 Fabio Nelli de Espinosa, banquero vallisoletano hijo del acaudalado banquero sienés Alfonso Nelli, manda construir este palacio. El edificio se presenta como símbolo del poder, riqueza y cultura de su propietario, acorde a la idea renacentista de permanecer en la Historia. El resultado es un | museo de la ciudad de Valladolid, (España)" ;
    tour:label "Museo de Valladolid" ;
    tour:latitude "41.6560174"^^xsd:float ;
    tour:longDescription "El Museo de Valladolid, anteriormente conocido como Museo Arqueológico Provincial, alberga importantes colecciones de Arqueología y Bellas Artes. Se encuentra en un edificio histórico que fue restaurado en 1967, simbolizando la riqueza cultural de la ciudad y ofreciendo a los visitantes una visión de su patrimonio artístico e histórico." ;
    tour:longitude "-4.7285835"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Museo que alberga colecciones de Arqueología y Bellas Artes." ;
    tour:type "TouristAttraction" ;
    tour:url "https://info.valladolid.es/disfruta/patrimonio/palacios/palacio-de-fabio-nelli" .

