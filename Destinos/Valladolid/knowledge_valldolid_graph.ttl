ex:rias_baixas a tour:Entity ;
    rdfs:label "Rías Baixas" ;
    tour:description "La finca donde se encuentra la bodega, LA GRANJA SARDÓN, está vinculada con el Conde de Ansúrez, en el S. XII, por lo que podría considerarse la finca más antigua de España. En 1999, los socios de Granja Sardón fundan Quinta Sardonia, y en 2010 fue adquirido por Terras Gauda, grupo que además cuenta | denominación de origen de España" ;
    tour:label "Rías Baixas" ;
    tour:latitude "41.6157252"^^xsd:float ;
    tour:longDescription "Rías Baixas es una reconocida región vinícola en Galicia, famosa por sus vinos blancos, especialmente el Albariño. Forma parte del patrimonio vitivinícola de España y es un destino popular para los amantes del vino que buscan experiencias en bodegas locales." ;
    tour:longitude "-4.4509808"^^xsd:float ;
    tour:score "1.0"^^xsd:float ;
    tour:shortDescription "Región vinícola en Galicia, España." ;
    tour:type "Place" ;
    tour:url "https://info.valladolid.es/quinta-sardonia" .

